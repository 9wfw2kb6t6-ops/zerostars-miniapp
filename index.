<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZeroStars</title>
<style>
body{font-family:Arial,sans-serif;background:#0f172a;color:white;margin:0;padding:20px;text-align:center}
.coin{width:180px;height:180px;border-radius:50%;background:gold;color:#111;
display:flex;align-items:center;justify-content:center;font-size:72px;
margin:20px auto;cursor:pointer}
button{padding:10px 15px;margin:5px}
#leaderboard{margin-top:20px;background:#111827;padding:10px;border-radius:10px}
.bar{height:16px;background:#1f2937;border-radius:8px;overflow:hidden}
.fill{height:100%;background:#22c55e;width:100%}
</style>
</head>
<body>
<h1>⭐ ZeroStars</h1>
<h2 id="coins">0</h2>

<div class="bar"><div id="energyFill" class="fill"></div></div>
<p id="energyText">100 / 100 Energy</p>

<div class="coin" onclick="mine()">⭐</div>

<button id="upgradeBtn" onclick="upgradePickaxe()">⛏ Upgrade (50)</button>
<button id="autoBtn" onclick="buyAutoMiner()">🤖 Auto Miner (100)</button>
<p id="autoCount">Auto Miners: 0</p>

<div id="leaderboard"><h3>🏆 Leaderboard</h3></div>

<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>

<script>
const firebaseConfig = {
  apiKey: "AIzaSyCXrAg3IseCTaLXCQlyc3t9cflmzjF3YKA",
  authDomain: "zerostars-bf9c6.firebaseapp.com",
  projectId: "zerostars-bf9c6",
  storageBucket: "zerostars-bf9c6.firebasestorage.app",
  messagingSenderId: "123440971770",
  appId: "1:123440971770:web:4c8d62f1bc5ca2ebe8ae43"
};

firebase.initializeApp(firebaseConfig);
const db = firebase.firestore();

let coins=0, energy=100, maxEnergy=100;
let clickPower=1, upgradeCost=50;
let autoMiner=0, autoMinerCost=100;

let username=localStorage.getItem("username") || prompt("Enter Username","Player");
localStorage.setItem("username", username);

function updateUI(){
 document.getElementById("coins").innerText=coins;
 document.getElementById("energyText").innerText=`${energy} / ${maxEnergy} Energy`;
 document.getElementById("energyFill").style.width=((energy/maxEnergy)*100)+"%";
}

function mine(){
 if(energy<=0) return;
 coins+=clickPower;
 energy--;
 updateUI();
 saveScore();
}

function upgradePickaxe(){
 if(coins<upgradeCost) return;
 coins-=upgradeCost;
 clickPower++;
 upgradeCost=Math.floor(upgradeCost*1.5);
 document.getElementById("upgradeBtn").innerText=`⛏ Upgrade (${upgradeCost})`;
 updateUI();
}

function buyAutoMiner(){
 if(coins<autoMinerCost) return;
 coins-=autoMinerCost;
 autoMiner++;
 autoMinerCost=Math.floor(autoMinerCost*1.8);
 document.getElementById("autoBtn").innerText=`🤖 Auto Miner (${autoMinerCost})`;
 document.getElementById("autoCount").innerText=`Auto Miners: ${autoMiner}`;
 updateUI();
}

async function saveScore(){
 try{
 await db.collection("leaderboard").doc(username).set({username,coins});
 }catch(e){console.log(e);}
}

async function loadLeaderboard(){
 try{
 const snap=await db.collection("leaderboard").orderBy("coins","desc").limit(10).get();
 let html="<h3>🏆 Leaderboard</h3>";
 snap.forEach(doc=>{
   const p=doc.data();
   html+=`<div>${p.username} - ${p.coins}</div>`;
 });
 document.getElementById("leaderboard").innerHTML=html;
 }catch(e){console.log(e);}
}

setInterval(()=>{
 if(energy<maxEnergy){energy++;updateUI();}
},1000);

setInterval(()=>{
 if(autoMiner>0){
   coins+=autoMiner;
   updateUI();
   saveScore();
 }
},1000);

setInterval(loadLeaderboard,5000);
updateUI();
loadLeaderboard();
</script>
</body>
</html>
